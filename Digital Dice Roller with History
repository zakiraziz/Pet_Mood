#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define MAX_HISTORY 20

void displayDice(int num) {
    char *dice[] = {
        "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ         в”Ӯ\nв”Ӯ    в—Ҹ    в”Ӯ\nв”Ӯ         в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ",
        "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ в—Ҹ       в”Ӯ\nв”Ӯ         в”Ӯ\nв”Ӯ       в—Ҹ в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ",
        "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ в—Ҹ       в”Ӯ\nв”Ӯ    в—Ҹ    в”Ӯ\nв”Ӯ       в—Ҹ в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ",
        "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ в—Ҹ     в—Ҹ в”Ӯ\nв”Ӯ         в”Ӯ\nв”Ӯ в—Ҹ     в—Ҹ в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ",
        "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ в—Ҹ     в—Ҹ в”Ӯ\nв”Ӯ    в—Ҹ    в”Ӯ\nв”Ӯ в—Ҹ     в—Ҹ в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ",
        "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ в—Ҹ     в—Ҹ в”Ӯ\nв”Ӯ в—Ҹ     в—Ҹ в”Ӯ\nв”Ӯ в—Ҹ     в—Ҹ в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"
    };
    printf("%s\n", dice[num-1]);
}

int main() {
    int history[MAX_HISTORY];
    int count = 0;
    char choice;
    
    srand(time(0));
    
    printf("рҹҺІ Dice Roller Simulator\n");
    printf("Press 'r' to roll, 'h' for history, 'q' to quit\n");
    
    while(1) {
        printf("\n> ");
        scanf(" %c", &choice);
        
        if(choice == 'r') {
            int roll = rand() % 6 + 1;
            printf("\nрҹҺІ You rolled: %d\n", roll);
            displayDice(roll);
            
            if(count < MAX_HISTORY) {
                history[count++] = roll;
            } else {
                // Shift history
                for(int i = 0; i < MAX_HISTORY-1; i++)
                    history[i] = history[i+1];
                history[MAX_HISTORY-1] = roll;
            }
        }
        else if(choice == 'h') {
            printf("\nрҹ“Ҡ Roll History:\n");
            if(count == 0) {
                printf("No rolls yet!\n");
            } else {
                for(int i = 0; i < count; i++) {
                    printf("Roll %d: %d\n", i+1, history[i]);
                }
            }
        }
        else if(choice == 'q') {
            printf("Thanks for playing! рҹҺІ\n");
            break;
        }
        else {
            printf("Invalid command!\n");
        }
    }
    return 0;
}